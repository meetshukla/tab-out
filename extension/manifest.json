{
  "manifest_version": 3,
  "name": "Tab Out",
  "version": "2.0.0",
  "description": "Popup-based tab organizer that groups the current window by site while keeping Tab Out's cleanup tools.",
  "permissions": ["tabs", "tabGroups", "storage", "activeTab"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Tab Out",
    "default_popup": "index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
